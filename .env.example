# Copy to .env for local development. Never commit the real .env.

# Local Postgres via docker-compose (see docker-compose.yml):
DATABASE_URL=postgresql://sanchay:sanchay_dev_password@localhost:5432/sanchay

# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of origins allowed to call this API from a browser.
CORS_ORIGINS=http://localhost:5173,https://chandramcsr.github.io
