# Copy this to .env.prod and fill in real values. Never commit
# .env.prod itself — it's already covered by the same .gitignore
# pattern as .env.

# Neon's connection string — Neon's dashboard gives you this directly.
# Must start with postgresql:// (not postgres://) for SQLAlchemy's
# async driver to pick it up correctly.
DATABASE_URL=postgresql://user:password@host/dbname

# Generate once, keep secret, never rotate casually — rotating
# invalidates every existing session and refresh token.
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Comma-separated, no trailing slashes, no spaces after commas.
CORS_ORIGINS=https://chandramcsr.github.io,http://localhost:5173

# Optional — omit to keep the dev fallback (logs reset/verification
# links instead of emailing them, fine for early testing).
RESEND_API_KEY=

# Where password-reset and verification links should point.
FRONTEND_URL=https://chandramcsr.github.io/ledger-app/
